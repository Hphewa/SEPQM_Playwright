{
  "name": "sepqm-playwright-task-manager",
  "version": "1.0.0",
  "private": true,
  "description": "Mini task manager project for Playwright fixtures, assertions, mocking, and reporting",
  "scripts": {
    "start": "node src/server.js",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report",

    "demo:assertions:headed": "playwright test tests/01-assertions.spec.js --headed",
    "demo:assertions:debug": "playwright test tests/01-assertions.spec.js --debug",

    "demo:fail:headed": "playwright test tests/05-demo-fail.spec.js --headed",
    "demo:fail:debug": "playwright test tests/05-demo-fail.spec.js --debug"
  },
  "dependencies": {
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0"
  },
  "engines": {
    "node": ">=18"
  }
}